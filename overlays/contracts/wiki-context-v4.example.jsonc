      "displayPath": ".shared-superpowers/wiki/frontend/contracts.md",
      "wikiPath": "frontend/contracts.md",
      // Preserve revision metadata from the MCP read so execution can detect remote wiki drift before rereading.
      "revision": {
        "ref": "main",

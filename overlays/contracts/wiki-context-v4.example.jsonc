{
  // Generated by superpower-adapter.
  // AI-facing authoring contract for docs/superpowers/plans/<plan-stem>.wiki-context.json.
  // Planning agents should adapt this shape from wiki-researcher selected pages and sections.
  // wiki-researcher selects candidate sections only; it must not create taskWikiRefs or taskFingerprint.
  // taskWikiRefs are generated only after the final Superpowers plan has real stable task IDs.
  // Do not inspect scripts/wiki_context_render.py to infer this format; that script is only for validation/rendering.
  //
  // schemaVersion 4 routing model: ALL routing lives on each section's `destination` block. There are no
  // separate globalWikiRefs / wikiRefs collections and no legacy `appliesTo` field. A section is reached by:
  //   - destination.kind = "global"        -> every task and reviewer (no destination.tasks)
  //   - destination.kind = "task-bound"    -> only the plan tasks listed in destination.tasks: ["1", ...]
  //   - destination.kind = "planning-only" -> not injected at execution (shaped task design only)
  // So after authoring the JSON sidecar you only: write each section's destination.reason, fix any wrong
  // destination.kind, and list destination.tasks for task-bound sections. Then stamp taskFingerprint
  // mechanically -- this also validates execution readiness and writes the sidecar in place. Never
  // hand-write taskFingerprint:
  // python3 <plugin-root>/scripts/wiki_context_render.py docs/superpowers/plans/<plan-stem>.wiki-context.json --bind-fingerprints --strict --execution-ready --plan-path docs/superpowers/plans/<plan-stem>.md
  // Before execution/SDD, run exactly one fingerprint preflight:
  // python3 <plugin-root>/scripts/wiki_context_render.py docs/superpowers/plans/<plan-stem>.wiki-context.json --fingerprint-preflight --strict --execution-ready --plan-path docs/superpowers/plans/<plan-stem>.md
  "schemaVersion": 4,
  "kind": "superpower-adapter.wiki-context",
  "generatedBy": "superpower-adapter",
  "planPath": "docs/superpowers/plans/example.md",
  // Optional. When any selected page is source: github_mcp, record the shared wiki identity ONCE here
  // from shared_wiki_status (repoUrl + baseBranch + revision). The shared-wiki MCP server self-configures
  // per project from .shared-superpowers/settings.json -> wiki.sharedMcp, so this captures WHICH shared
  // wiki this plan was built against. Before trusting github_mcp rereads, execution confirms the connected
  // server still serves this repoUrl; a mismatch means the project rebound its shared wiki between planning
  // and execution. Omit this block entirely when no github_mcp page is selected. Per-page revision still
  // lives on each github_mcp page.
  "sharedWiki": {
    "source": "github_mcp",
    "repoUrl": "https://github.com/acme/platform-wiki.git",
    "baseBranch": "master",
    "revision": { "ref": "master", "commitSha": "abcdef1234567890", "shortSha": "abcdef1" }
  },
  "taskRouting": {
    // candidate_sections_only is not execution-ready. confirmed is required for execution/SDD.
    "status": "confirmed",
    "planTaskFormat": "superpower-adapter-plan-task-heading-v1",
    "fingerprintAlgorithm": "sha256:superpower-adapter-task-text-v1",
    "selectedSectionsFrozen": true,
    "refreshPolicy": "refresh-taskWikiRefs-and-fingerprints-only"
  },
  "wikiPages": [
    {
      // Local project wiki page. Use root=project for .superpowers/wiki pages.
      "root": "project",
      "source": "local",
      "displayPath": ".superpowers/wiki/frontend/hook-guidelines.md",
      "localPath": "frontend/hook-guidelines.md",
      // documentContext belongs once per page, usually from the companion <stem>.index.md title/overview.
      // Do not put documentContext inside section objects; strict validation rejects section-level documentContext.
      "documentContext": {
        "title": "Hook Guidelines",
        "overview": "Project-private hook rules for generated form adapters.",
        "scope": "Generated form adapter field-update conventions.",
        "contextSource": ".superpowers/wiki/frontend/hook-guidelines.index.md",
        "caveats": []
      },
      "sections": [
        {
          "sectionId": "path-based-update",
          "section_name": "path-based-update",

          "confidence": "high",
          "reason": "Field updates are in scope.",
          "relevanceTo": "form field updates and adapter state writes",
          "hardConstraint": true,
          // Routing for this section. hardConstraint/direct sections must be task-bound or global,
          // never planning-only. task-bound sections list the plan task ids they apply to in `tasks`.
          "destination": {
            "kind": "task-bound",
            "reason": "Only tasks that change generated form adapter field updates need this section injected.",
            "tasks": ["1"]
          },
          // Constraint categories are exactly implementation, test, review, and general.
          // Use general when a selected constraint cannot be categorized confidently.
          "constraints": {

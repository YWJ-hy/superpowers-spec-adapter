#!/usr/bin/env bash
# PostToolUse hook for superpower-adapter.
# Generated by superpower-adapter.
#
# Fires after a Bash tool call. When the command integrated a development branch
# into its integration branch (a "work accepted" merge), it injects a gentle
# reminder for Claude to run the `update-wiki` skill, so durable implementation
# knowledge is reviewed even when the user merges outside
# `finishing-a-development-branch` (e.g. a bare `git merge` back to main or an
# iteration branch after manual testing).
#
# Design (locked with the user):
# - Trigger on the merge ACTION, not on a hardcoded target branch. `git merge`
#   (incl. `git -C <dir> merge`), `git merge --continue`, and `gh pr merge` count.
# - Deliberately simple: any completed merge fires the reminder. Merge direction
#   (which branch merged into which) is NOT judged. Only `--abort`/`--quit` and an
#   unfinished/conflicted merge (MERGE_HEAD present) are skipped. Refine later if a
#   real need to suppress sync-direction merges arises.
# - Do NOT gate on local wiki presence: fire on every finalize merge and let the
#   update-wiki skill's built-in gate decide whether anything should persist (it
#   defaults to skip and handles project wiki, local shared wiki, and remote MCP
#   shared wiki). Rationale: shared wiki may be a globally-configured MCP server
#   with no local footprint, so any filesystem gate would miss it.
# - Never break the session: any error or missing dependency exits 0 with no output.

set -uo pipefail

# JSON parsing + git state inspection need python3, which the whole adapter already
# depends on. If it is somehow unavailable, stay silent rather than disrupt the user.
command -v python3 >/dev/null 2>&1 || exit 0

# Capture the PostToolUse payload from stdin and hand it to python via the
# environment, leaving python's own stdin free for the inline program below.
HOOK_INPUT="$(cat)"

# Fast path: this hook fires on every Bash tool call, so cheaply reject the
# common case before spawning python. Every merge we care about (git merge,
# git merge --continue, gh pr merge) contains the substring "merge"; if it is
# absent from the whole payload, there is nothing to do.
case "$HOOK_INPUT" in
  *merge*) : ;;
  *) exit 0 ;;
esac

export HOOK_INPUT

python3 <<'PY' || exit 0
import json
import os
import re
import subprocess
import sys

NOOP = ""


def emit_nothing():
    sys.stdout.write(NOOP)
    sys.exit(0)


def git(repo_dir, *args):
    """Run a read-only git command; return stripped stdout or None on any failure."""
    try:
        result = subprocess.run(
            ["git", "-C", repo_dir, *args],
            capture_output=True,
            text=True,
            timeout=10,
        )
    except (OSError, subprocess.SubprocessError):
        return None
    if result.returncode != 0:
        return None
    return result.stdout.strip()


def split_segments(command):
    """Break a compound shell command into individual call segments."""
    return re.split(r"&&|\|\||[;|\n]", command)


def tokenize(segment):
    import shlex

    try:
        return shlex.split(segment)
    except ValueError:
        return segment.split()


VALUE_OPTS = {
    "-m",
    "--message",
    "-F",
    "--file",
    "-X",
    "--strategy",
    "--strategy-option",
    "--into-name",
    "-S",
    "--gpg-sign",
}


def basename(ref):
    return ref.rsplit("/", 1)[-1] if ref else ref


def parse_merge(command):
    """Return (is_merge, repo_subdir_or_None, merged_ref_or_None, is_abort)."""
    for segment in split_segments(command):
        tokens = tokenize(segment)
        if not tokens:
            continue

        # gh pr merge -> always a finalize-direction integration, ref unknown.
        for i in range(len(tokens) - 2):
            if tokens[i] == "gh" and tokens[i + 1] == "pr" and tokens[i + 2] == "merge":
                return True, None, None, False

        if "git" not in tokens:
            continue
        gi = tokens.index("git")
        # Collect git global options between `git` and the subcommand.
        repo_subdir = None
        j = gi + 1
        while j < len(tokens) and tokens[j].startswith("-"):
            if tokens[j] in ("-C", "--git-dir", "-c") and j + 1 < len(tokens):
                if tokens[j] == "-C":
                    repo_subdir = tokens[j + 1]
                j += 2
                continue
            j += 1
        if j >= len(tokens) or tokens[j] != "merge":
            continue

        merge_args = tokens[j + 1 :]
        if "--abort" in merge_args or "--quit" in merge_args:
            return True, repo_subdir, None, True
        if "--continue" in merge_args:
            return True, repo_subdir, None, False

        merged_ref = None
        skip_next = False
        for arg in merge_args:
            if skip_next:
                skip_next = False
                continue
            if arg in VALUE_OPTS:
                skip_next = True
                continue
            if arg.startswith("-"):
                continue
            merged_ref = arg
            break
        return True, repo_subdir, merged_ref, False
    return False, None, None, False


def main():
    try:
        data = json.loads(os.environ.get("HOOK_INPUT", "") or "{}")
    except (ValueError, TypeError):
        emit_nothing()
    if not isinstance(data, dict):
        emit_nothing()

    tool_input = data.get("tool_input") or {}
    command = tool_input.get("command") if isinstance(tool_input, dict) else None
    if not isinstance(command, str) or not command.strip():
        emit_nothing()

    cwd = data.get("cwd")
    if not isinstance(cwd, str) or not cwd:
        cwd = os.getcwd()

    is_merge, repo_subdir, merged_ref, is_abort = parse_merge(command)
    if not is_merge or is_abort:
        emit_nothing()

    # Resolve the repo directory the merge acted on (honor `git -C <dir>`).
    repo_dir = cwd
    if repo_subdir:
        repo_dir = repo_subdir if os.path.isabs(repo_subdir) else os.path.join(cwd, repo_subdir)

    # Conflict guard: do not nag while a merge is unfinished/conflicted.
    if git(repo_dir, "rev-parse", "-q", "--verify", "MERGE_HEAD") is not None:
        emit_nothing()

    # Any completed merge fires the reminder. Merge direction (which branch was
    # merged into which) is intentionally NOT judged — kept deliberately simple;
    # refine later if a real need to suppress sync-direction merges arises.

    reminder = (
        "A merge that integrates a development branch into its integration branch just completed. "
        "If this finalized implementation, debugging, or review work, use the `update-wiki` skill to "
        "review whether the work produced durable implementation knowledge that should persist to the "
        "project or shared wiki before you treat the task as done. If nothing durable should persist, "
        "state an explicit skip reason. This is a post-merge knowledge-capture reminder only; it does "
        "not assert that implementation is verified or complete."
    )

    # Match the platform output contract used by the SessionStart hook.
    if os.environ.get("CURSOR_PLUGIN_ROOT"):
        payload = {"additional_context": reminder}
    elif os.environ.get("CLAUDE_PLUGIN_ROOT") and not os.environ.get("COPILOT_CLI"):
        payload = {
            "hookSpecificOutput": {
                "hookEventName": "PostToolUse",
                "additionalContext": reminder,
            }
        }
    else:
        payload = {"additionalContext": reminder}

    sys.stdout.write(json.dumps(payload))
    sys.exit(0)


main()
PY

exit 0
